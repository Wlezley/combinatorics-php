{
    "name": "lishack/combinatorics-php",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lishack\\Combinatorics\\": "src/"
        }
    },
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-webmozart-assert": "^2.0",
        "slevomat/coding-standard": "^8.30"
    },
    "authors": [
        {
            "name": "Wlezley Lishack",
            "email": "wlezley.lishack@gmail.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.4"
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint-fix": "phpcbf",
        "phpstan": "phpstan analyse --memory-limit 512M"
    }
}
